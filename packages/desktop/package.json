{
  "name": "@mantra/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "electron .",
    "dist": "node esbuild.mjs && electron-builder --mac --publish never"
  },
  "description": "Voice + console control plane over a fleet of Claude Code agent crews.",
  "author": "Vedant Patil",
  "comment": "All runtime code is bundled into dist/ by esbuild; the Agent SDK stays external (it uses import.meta to find its own subprocess assets) and is mapped into the app via build.files. So there are NO production dependencies for electron-builder to collect — avoids the workspace-hoisting packaging error.",
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@mantra/core": "0.0.1",
    "@mantra/orchestrator": "0.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "43.1.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2"
  },
  "build": {
    "appId": "com.vedant.mantra",
    "productName": "Mantra",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      { "from": "../../node_modules/@anthropic-ai/claude-agent-sdk", "to": "node_modules/@anthropic-ai/claude-agent-sdk" }
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Mantra"
    }
  }
}
